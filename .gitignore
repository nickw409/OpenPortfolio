node_modules/
dist/
build/
out/
coverage/
.vite/

# Local data — never committed
data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code per-machine settings (project-level settings.json may be committed; .local is private)
.claude/settings.local.json

# Worktrees live inside the repo at worktrees/<slug>/ and are managed by
# `git worktree`, not tracked as content.
worktrees/

# Python bytecode cache (helpers in scripts/ may produce this when imported
# or syntax-checked).
__pycache__/

# Agentic workspace metadata (per-session state, never source).
.superpowers/
