{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm run typecheck*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm run format*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm run dev*)",
      "Bash(pnpm db:generate*)",
      "Bash(pnpm run db:generate*)",
      "Bash(pnpm install*)",
      "Bash(pnpm i)",
      "Bash(pnpm import*)",
      "Bash(pnpm --version)",
      "Bash(pnpm ls*)",
      "Bash(pnpm list*)",
      "Bash(pnpm view*)",
      "Bash(pnpm outdated*)",
      "Bash(pnpm why*)",
      "Bash(pnpm exec*)",
      "Bash(pnpm worktree*)",
      "Bash(pnpm worktree-rm*)",

      "Bash(pnpm -C worktrees/*)",

      "Bash(npx vitest*)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(npx tsc*)",
      "Bash(npx tsx*)",
      "Bash(npx drizzle-kit*)",
      "Bash(node --version)",
      "Bash(node -e *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git restore*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git switch*)",
      "Bash(git worktree*)",

      "Bash(git -C worktrees/*)",

      "Bash(python3 scripts/*)",
      "Bash(python3 worktrees/*/scripts/*)",

      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(ag*)",
      "Bash(ls*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(diff*)",
      "Bash(file*)",
      "Bash(stat*)",
      "Bash(printf*)",
      "Bash(date*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(command -v*)",
      "Bash(uname*)",
      "Bash(hostname)",
      "Bash(whoami)",
      "Bash(id*)",
      "Bash(df*)",
      "Bash(du*)",
      "Bash(free*)",
      "Bash(ps*)",
      "Bash(nproc)",
      "Bash(tree*)",
      "Bash(jq*)",
      "Bash(cat)",
      "Bash(echo*)",

      "Bash(find * -name *)",
      "Bash(find * -type *)",
      "Bash(find * -path *)",
      "Bash(find * -newer *)",
      "Bash(find * -size *)",
      "Bash(find * -maxdepth *)",
      "Bash(sed -n *)",
      "Bash(sed -e *)",
      "Bash(awk*)",

      "Bash(sqlite3 *.db *)",
      "Bash(sqlite3 *.sqlite *)",

      "Read(//tmp/**)"
    ],
    "deny": [
      "Bash(*&& rm -rf*)",
      "Bash(*; rm -rf*)",
      "Bash(*| sh*)",
      "Bash(*| bash*)",
      "Bash(*sudo *)",
      "Bash(*curl * | *)",
      "Bash(*wget * | *)",
      "Bash(*git push --force*)",
      "Bash(*git push -f *)",
      "Bash(*git reset --hard *)",
      "Bash(*git clean -fd*)",
      "Bash(*--no-verify*)",
      "Bash(*chmod -R *)",
      "Bash(*find * -delete*)",
      "Bash(*find * -exec*)",
      "Bash(*find * -execdir*)",
      "Bash(*find * -ok*)",
      "Bash(*sed -i*)",
      "Bash(*sed --in-place*)",
      "Bash(*awk*system*)",
      "Bash(*awk*print *> *)",
      "Bash(*> /dev/sd*)",
      "Bash(*dd if=*of=/dev/*)",
      "Bash(*npm publish*)",
      "Bash(*pnpm publish*)",
      "Bash(*rm -rf node_modules*)"
    ],
    "additionalDirectories": ["/tmp"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/check_worktree_paths.py\""
          }
        ]
      }
    ]
  }
}
